# CareerBuddyAI Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env to Git.

# App
APP_ENV=development
DEBUG=true

# API Keys (fill these in your local .env)
OPENAI_API_KEY=
GEMINI_API_KEY=

